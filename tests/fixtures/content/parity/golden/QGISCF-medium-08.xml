<Regex id="Pattern_bail_condition_document_bail_condition_terms_bail-condition-document">(?i)\b(bail\s+(?:conditions?|undertaking|order|variation)|surety\s+(?:agreement|amount)|reporting\s+conditions?|curfew\s+(?:condition|hours)|exclusion\s+zone|no[\-\s]contact\s+(?:condition|order))\b</Regex>
<Regex id="Pattern_bail_condition_document_bail_act_reference_bail-condition-document">(?i)\bBail\s+Act\s+1980\b</Regex>
<Regex id="Pattern_bail_condition_document_bail_section_reference_bail-condition-document">(?i)\bs\.(?:\s+)?(?:11|16|17|29)\s+Bail\s+Act\b</Regex>
<Regex id="Pattern_community_corrections_order_corrections_order_terms_community-corrections-order">(?i)\b(community\s+corrections?\s+order|probation\s+order|parole\s+(?:conditions?|order|board)|community\s+service\s+order|supervision\s+order|intensive\s+correction\s+order)\b</Regex>
<Regex id="Pattern_community_corrections_order_corrective_services_act_community-corrections-order">(?i)\bCorrective\s+Services\s+Act\s+2006\b</Regex>
<Regex id="Pattern_community_corrections_order_corrections_reference_community-corrections-order">\b(?:CCO|PB)-\d{4}-[A-Z]{2,4}-?\d{3,5}\b</Regex>
<Regex id="Pattern_domestic_violence_order_application_dvo_reference_number_domestic-violence-order-application">\bDVO-\d{4}-\d{3,5}\b</Regex>
<Regex id="Pattern_domestic_violence_order_application_dvo_terms_domestic-violence-order-application">(?i)\b(domestic\s+violence\s+(?:order|application)|protection\s+order\s+(?:application|conditions?)|ouster\s+(?:condition|order)|temporary\s+protection\s+order)\b</Regex>
<Regex id="Pattern_domestic_violence_order_application_dfv_act_reference_domestic-violence-order-application">(?i)\bDomestic\s+and\s+Family\s+Violence\s+Protection\s+Act\s+2012\b</Regex>
<Regex id="Pattern_police_body_worn_camera_metadata_bwc_metadata_terms_police-body-worn-camera-metadata">(?i)\b(body\s+worn\s+camera\s+(?:metadata|log|record|activation)|BWC\s+(?:activation|footage|reference|log|record))\b</Regex>
<Regex id="Pattern_police_body_worn_camera_metadata_bwc_unit_reference_police-body-worn-camera-metadata">\bBWC-[A-Z]{2,4}-\d{3,5}\b</Regex>
<Regex id="Pattern_police_body_worn_camera_metadata_activation_timestamp_police-body-worn-camera-metadata">(?i)\b(?:activation|deactivation)\s+timestamp\b</Regex>
<Regex id="Pattern_qps_incident_report_qps_reference_number_qps-incident-report">\bQP-\d{4}-\d{5,7}\b</Regex>
<Regex id="Pattern_qps_incident_report_occurrence_number_qps-incident-report">\bOCC-\d{5,7}\b</Regex>
