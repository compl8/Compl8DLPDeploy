{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PhaseResult",
  "type": "object",
  "required": ["schemaVersion","phase","action","status","startedAt","completedAt","artifacts","errors"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "phase": { "type": "string", "enum": ["classifiers","labels","dlprules","refit"] },
    "action": { "type": "string" },
    "status": { "type": "string", "enum": ["success","partial","failed"] },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name","action"],
        "properties": {
          "name": { "type": "string" },
          "action": { "type": "string" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reportPath": { "type": "string" }
  }
}
