{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ArchiveIndex",
  "type": "object",
  "required": ["schemaVersion","deployments"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "deployments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sessionId","tenant","targetEnvironment","result","archivedAt","archivePath","targetSha256","resultSha256"],
        "properties": {
          "sessionId": { "type": "string" },
          "tenant": { "type": "string" },
          "targetEnvironment": { "type": "string" },
          "result": { "type": "string", "enum": ["succeeded","partial","failed","rolledback"] },
          "archivedAt": { "type": "string" },
          "archivePath": { "type": "string" },
          "targetSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "resultSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
