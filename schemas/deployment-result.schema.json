{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DeploymentResult",
  "type": "object",
  "required": ["schemaVersion","status","verifiedAt","missing","extras","mismatches","summary"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "status": { "type": "string", "enum": ["succeeded","partial","failed","rolledback"] },
    "verifiedAt": { "type": "string", "format": "date-time" },
    "missing": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifactType","name"],
        "properties": {
          "artifactType": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "extras": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifactType","name"],
        "properties": {
          "artifactType": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "mismatches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifactType","name","field"],
        "properties": {
          "artifactType": { "type": "string" },
          "name": { "type": "string" },
          "field": { "type": "string" },
          "target": {},
          "actual": {}
        }
      }
    },
    "summary": { "type": "object" }
  }
}
